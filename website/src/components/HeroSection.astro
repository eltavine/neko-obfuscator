---
// Hero section — first impression with GSAP entrance animation
---

<section class="hero" id="hero">
  <div class="container hero-inner">
    <h1 class="hero-title" data-animate>
      Advanced JVM obfuscation,<br />
      <span class="hero-title-accent">zero-overhead native execution.</span>
    </h1>
    <p class="hero-subtitle" data-animate>
      NekoObfuscator is an open-source Java bytecode and native obfuscation toolkit
      that rivals commercial tools like ZKM — with deep HotSpot integration that
      bypasses JNI entirely, delivering native performance indistinguishable from raw speeds.
    </p>
    <div class="hero-actions" data-animate>
      <a href="https://github.com/Fadouse/neko-obfuscator" class="btn-primary" target="_blank" rel="noopener">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        View on GitHub
      </a>
      <a href="#features" class="btn-secondary">
        Explore features
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17l9.2-9.2M17 17V7H7"/></svg>
      </a>
    </div>
  </div>

  <!-- Ambient gradient -->
  <div class="hero-ambient"></div>
</section>

<script>
  import { gsap } from 'gsap';

  document.addEventListener('astro:page-load', () => {
    gsap.fromTo('[data-animate]', {
      y: 40,
      opacity: 0,
    }, {
      y: 0,
      opacity: 1,
      duration: 1,
      stagger: 0.15,
      ease: 'power3.out',
    });
  });
</script>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: calc(var(--nav-height) + 80px) 0 80px;
    overflow: hidden;
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: 760px;
  }

  .hero-title {
    font-size: clamp(2.6rem, 6vw, 4.4rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.08;
    margin-bottom: 24px;
  }

  .hero-title-accent {
    color: var(--accent);
  }

  .hero-subtitle {
    font-size: 1.08rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: 36px;
    max-width: 560px;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.88rem;
    font-weight: 600;
    padding: 12px 22px;
    border-radius: 12px;
    background: var(--accent);
    color: #fff;
    border: none;
    cursor: pointer;
    transition: transform 0.2s var(--ease-spring), box-shadow 0.2s var(--ease-spring), opacity 0.2s ease;
  }

  .btn-primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 24px var(--accent-glow);
    opacity: 1;
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.88rem;
    font-weight: 500;
    padding: 12px 22px;
    border-radius: 12px;
    background: var(--bg-card);
    color: var(--text-primary);
    border: 1px solid var(--border);
    cursor: pointer;
    transition: all 0.2s var(--ease-spring);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .btn-secondary:hover {
    border-color: var(--border-strong);
    background: var(--bg-card-hover);
    opacity: 1;
  }

  /* Ambient gradient orb */
  .hero-ambient {
    position: absolute;
    top: -40%;
    right: -30%;
    width: 700px;
    height: 700px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--accent-glow) 0%, transparent 70%);
    filter: blur(80px);
    pointer-events: none;
    animation: ambient-drift 12s ease-in-out infinite;
  }

  @keyframes ambient-drift {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(-30px, 20px) scale(1.05); }
    66% { transform: translate(20px, -10px) scale(0.95); }
  }
</style>
